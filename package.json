{
  "name": "@cincpro/prosody",
  "version": "0.7.0",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "bindings.js",
    "bindings.d.ts",
    "README.md"
  ],
  "napi": {
    "name": "prosody",
    "triples": {
      "additional": [
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu",
        "aarch64-unknown-linux-musl",
        "aarch64-pc-windows-msvc",
        "armv7-unknown-linux-gnueabihf",
        "armv7-unknown-linux-musleabihf",
        "x86_64-unknown-linux-musl",
        "universal-apple-darwin"
      ]
    }
  },
  "license": "UNLICENSED",
  "dependencies": {
    "@opentelemetry/api": "^1",
    "@opentelemetry/core": "^2"
  },
  "devDependencies": {
    "@babel/core": "^7",
    "@babel/plugin-proposal-decorators": "^7",
    "@babel/preset-env": "^7",
    "@napi-rs/cli": "^2",
    "@opentelemetry/auto-instrumentations-node": "^0.57",
    "@opentelemetry/sdk-metrics": "^2",
    "@opentelemetry/sdk-node": "^0.200",
    "@opentelemetry/sdk-trace-base": "^2",
    "@opentelemetry/sdk-trace-node": "^2",
    "jest": "^29",
    "prettier": "^3"
  },
  "engines": {
    "node": ">= 10"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --js bindings.js --dts bindings.d.ts --platform --no-const-enum --release",
    "build:debug": "napi build --js bindings.js --dts bindings.d.ts --platform --no-const-enum",
    "prepublishOnly": "napi prepublish -t npm --skip-gh-release",
    "test": "yarn run jest",
    "universal": "napi universal",
    "version": "napi version"
  },
  "packageManager": "yarn@4.4.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cincpro/prosody-js.git"
  },
  "description": "Javascript bindings for the Prosody Kafka client library",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
