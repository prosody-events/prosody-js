{
  "name": "@cincpro/prosody",
  "version": "1.2.2",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "bindings.js",
    "bindings.d.ts",
    "README.md"
  ],
  "napi": {
    "binaryName": "prosody",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "license": "UNLICENSED",
  "dependencies": {
    "@opentelemetry/api": "^1.9.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/plugin-proposal-decorators": "^7.28.0",
    "@babel/preset-env": "^7.28.3",
    "@napi-rs/cli": "^3.2.0",
    "@opentelemetry/auto-instrumentations-node": "^0.64.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.205.0",
    "@opentelemetry/sdk-metrics": "^2.1.0",
    "@opentelemetry/sdk-node": "^0.205.0",
    "@opentelemetry/sdk-trace-base": "^2.1.0",
    "@opentelemetry/sdk-trace-node": "^2.1.0",
    "jest": "^30.1.3",
    "prettier": "^3.6.2",
    "yarn-upgrade-all": "^0.7.5"
  },
  "engines": {
    "node": ">= 20"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --js bindings.js --dts bindings.d.ts --platform --no-const-enum --release",
    "build:debug": "napi build --js bindings.js --dts bindings.d.ts --platform --no-const-enum",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "napi prepublish -t npm --no-gh-release",
    "test": "yarn run jest",
    "universal": "napi universalize",
    "version": "napi version"
  },
  "packageManager": "yarn@4.4.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cincpro/prosody-js.git"
  },
  "description": "Javascript bindings for the Prosody Kafka client library",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
