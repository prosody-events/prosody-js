{
  "name": "@prosody-events/prosody",
  "version": "2.4.0",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "bindings.js",
    "bindings.d.ts",
    "README.md"
  ],
  "napi": {
    "binaryName": "prosody",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "license": "MIT",
  "peerDependencies": {
    "@sentry/node": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "@sentry/node": {
      "optional": true
    }
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.212.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@napi-rs/cli": "^3.5.1",
    "@opentelemetry/auto-instrumentations-node": "^0.70.1",
    "@opentelemetry/core": "^2.5.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.212.0",
    "@opentelemetry/sdk-metrics": "^2.5.1",
    "@opentelemetry/sdk-node": "^0.212.0",
    "@opentelemetry/sdk-trace-base": "^2.5.1",
    "@opentelemetry/sdk-trace-node": "^2.5.1",
    "@sentry/node": "^10.45.0",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "yarn-upgrade-all": "^0.7.5"
  },
  "engines": {
    "node": ">= 20"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --js bindings.js --dts bindings.d.ts --platform --no-const-enum --release",
    "build:debug": "napi build --js bindings.js --dts bindings.d.ts --platform --no-const-enum",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "napi prepublish -t npm --no-gh-release",
    "test": "NODE_OPTIONS='--experimental-vm-modules' yarn run jest",
    "universal": "napi universalize",
    "version": "napi version"
  },
  "packageManager": "yarn@4.4.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prosody-events/prosody-js.git"
  },
  "description": "Javascript bindings for the Prosody Kafka client library",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
